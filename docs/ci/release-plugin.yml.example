# Drop this file into `.github/workflows/release-plugin.yml` to enable.
# Kept under `docs/ci/` so the initial branch can be pushed without
# requiring the `workflow` OAuth scope; promoting it to a live workflow is
# a one-line move once an admin token is available.
#
# UH-68 — release the Hermes dashboard plugin as a GitHub Releases tarball.
#
# Trigger: pushed tag `plugin-v*` OR a tagged release event. We piggy-back on
# the existing `dev`/`main` CI for typecheck + bundle size; this workflow only
# runs the bundle + tarball + upload step on tags.
#
# Output: two tarballs attached to the GitHub Release —
#   * `hermes-plugin-<tag>.tar.gz` (version-pinned, for archival / pinning)
#   * `hermes-plugin.tar.gz`       (stable name, so the install one-liner
#     `releases/latest/download/hermes-plugin.tar.gz` keeps working).
# Layout inside each tarball mirrors `~/.hermes/plugins/uh/` (one extraction
# step = fully installed).
name: Release Hermes plugin

on:
  push:
    tags:
      - "plugin-v*"
  release:
    types: [published]
  workflow_dispatch:

permissions:
  contents: write

concurrency:
  group: release-plugin-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: false

jobs:
  package:
    name: Build + upload tarball
    runs-on: ubuntu-24.04
    timeout-minutes: 10
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 1

      - name: Setup Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: 1.3.14

      - name: Install dependencies
        run: bun install --frozen-lockfile

      - name: Build plugin bundle
        run: bun run plugin:build

      - name: Stage tarball contents
        run: |
          set -euo pipefail
          STAGE="$RUNNER_TEMP/hermes-plugin"
          mkdir -p "$STAGE/uh/dashboard" "$STAGE/uh/theme"
          cp -a apps/hermes-plugin/dashboard/manifest.json "$STAGE/uh/dashboard/"
          cp -a apps/hermes-plugin/dashboard/plugin_api.py "$STAGE/uh/dashboard/"
          cp -a apps/hermes-plugin/dashboard/dist "$STAGE/uh/dashboard/"
          cp -a apps/hermes-plugin/theme/ultimate-harness.yaml "$STAGE/uh/theme/"
          cp -a apps/hermes-plugin/README.md "$STAGE/uh/"
          # Build both the version-pinned and the stable-named tarballs so
          # `releases/latest/download/hermes-plugin.tar.gz` (used by the
          # install one-liner in README + runbook) keeps resolving.
          tar -czf "$RUNNER_TEMP/hermes-plugin-${GITHUB_REF_NAME}.tar.gz" -C "$STAGE" .
          cp "$RUNNER_TEMP/hermes-plugin-${GITHUB_REF_NAME}.tar.gz" "$RUNNER_TEMP/hermes-plugin.tar.gz"
          ls -la "$RUNNER_TEMP" | grep hermes-plugin

      - name: Attach to release
        if: github.event_name == 'release'
        uses: softprops/action-gh-release@v2
        with:
          files: |
            ${{ runner.temp }}/hermes-plugin-${{ github.ref_name }}.tar.gz
            ${{ runner.temp }}/hermes-plugin.tar.gz

      - name: Upload as workflow artifact
        if: github.event_name != 'release'
        uses: actions/upload-artifact@v4
        with:
          name: hermes-plugin-${{ github.ref_name }}
          path: |
            ${{ runner.temp }}/hermes-plugin-${{ github.ref_name }}.tar.gz
            ${{ runner.temp }}/hermes-plugin.tar.gz
          if-no-files-found: error
