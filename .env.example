# Ultimate Harness local development placeholders.
# Copy to .env only for local shells; never commit real provider keys or tokens.

# Runtime adapter credentials. Prefer shell/session injection over persistent files.
OPENROUTER_API_KEY=replace-with-openrouter-key

# Optional PostHog telemetry. Disabled unless UH_TELEMETRY is explicitly set.
# Captures aggregate command outcomes only: command name, status, exit code,
# duration, package version, and platform metadata.
UH_TELEMETRY=off
UH_POSTHOG_API_KEY=replace-with-posthog-project-api-key
UH_POSTHOG_HOST=https://us.i.posthog.com

# Hermes dashboard plugin development.
UH_PROJECT_ROOT=/absolute/path/to/project
UH_CLI_BIN=uh
UH_READ_TIMEOUT_S=30
UH_RUN_TIMEOUT_S=3600
UH_MAX_ARTIFACT_BYTES=5242880
UH_MAX_OVERRIDES_JSON_BYTES=8192
