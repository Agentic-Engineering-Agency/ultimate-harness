{
  "name": "@uh/docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && cp dist/client/_shell.html dist/client/index.html && printf '/* /index.html 200\\n' > dist/client/_redirects",
    "preview": "vite preview",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "deploy": "alchemy deploy --stage prod",
    "destroy": "alchemy destroy --stage prod",
    "alchemy:dev": "alchemy dev"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/start-static-server-functions": "1.166.41",
    "fumadocs-core": "^16.0.0",
    "fumadocs-mdx": "^15.0.0",
    "fumadocs-ui": "^16.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0",
    "tslib": "^2.8.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.11.6",
    "@cloudflare/workers-types": "^4.20250805.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "alchemy": "0.93.9",
    "nitro": "3.0.260429-beta",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
