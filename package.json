{
  "name": "@agenticengineeringagency/ultimate-harness",
  "version": "0.7.0",
  "description": "Runtime-agnostic software-development harness for agentic engineering work.",
  "type": "module",
  "bin": {
    "uh": "./dist/cli.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agentic-Engineering-Agency/ultimate-harness.git"
  },
  "homepage": "https://uh.agenticengineering.lat",
  "bugs": {
    "url": "https://github.com/Agentic-Engineering-Agency/ultimate-harness/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=20"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "docs/runbooks/",
    "docs/architecture/"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.tests.json --noEmit",
    "tui-spike": "bun bin/uh-tui-spike.tsx",
    "clean": "rm -rf dist",
    "publish:dry-run": "bun publish --dry-run",
    "plugin:build": "bun apps/hermes-plugin/esbuild.config.mjs",
    "plugin:watch": "bun apps/hermes-plugin/esbuild.config.mjs --watch",
    "plugin:typecheck": "tsc -p apps/hermes-plugin/dashboard/tsconfig.json --noEmit",
    "plugin:test": "pytest apps/hermes-plugin/dashboard/tests/"
  },
  "dependencies": {
    "@honcho-ai/sdk": "^2.1.1",
    "@opentui/core": "^0.2.13",
    "@opentui/solid": "^0.2.13",
    "commander": "latest",
    "solid-js": "1.9.12",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "^0.28.0",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
